{
    "commit-msg": {
        "enabled": true,
        "actions": [
            {
                "action": "\\CaptainHook\\App\\Hook\\Message\\Action\\Regex",
                "options": {
                    "regex": "#^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\\(.+\\))?:\\s.+#"
                }
            }
        ]
    },
    "pre-commit": {
        "enabled": true,
        "actions": [
            {
                "action": "./vendor/bin/pint"
            },
            {
                "action": "git add ."
            },
            {
                "action": "./vendor/bin/phpstan analyse --memory-limit=512M"
            }
        ]
    }
}